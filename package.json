{
  "name": "attention-crm",
  "private": true,
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  },
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i web/src/tailwind.css -o web/static/tailwind.css --minify",
